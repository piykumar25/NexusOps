# ═══════════════════════════════════════════════════════════════════
# NexusOps Configuration — Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# ─── LLM Configuration ──────────────────────────────────────────
# Use "test" for demo mode (no LLM required)
# Use "ollama:llama3.2:3b" for local Ollama (fast, 2GB)
# Use "ollama:llama3.1" for local Ollama (smarter, 4.9GB)
LLM_MODEL_NAME=test
OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Embedding Configuration ────────────────────────────────────
# Providers: "ollama" (default, free), "openai", "fallback" (no embeddings)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# ─── Qdrant Vector Database ─────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=nexusops-knowledge

# ─── Prometheus ──────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ─── Kafka ───────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9093

# ─── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://nexusops:nexusops_password@localhost:5432/nexusops_db

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── API Server ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8082
CORS_ORIGINS=["http://localhost:3000"]

# ─── Guardrails ──────────────────────────────────────────────────
GUARDRAIL_MAX_INPUT_LENGTH=4000
GUARDRAIL_RATE_LIMIT_REQUESTS=30
GUARDRAIL_RATE_LIMIT_WINDOW=60
GUARDRAIL_ENABLE_TOPIC_FILTER=true
GUARDRAIL_ENABLE_INJECTION_FILTER=true

# ─── Circuit Breaker ────────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# ─── Agent Timeouts ─────────────────────────────────────────────
AGENT_TIMEOUT_COORDINATOR=120.0
AGENT_TIMEOUT_SPECIALIST=60.0
AGENT_MAX_RETRIES=3

# ─── OpenAI (optional — only needed if using OpenAI embeddings) ─
# OPENAI_API_KEY=sk-...
